# Copie para .env.local e ajuste os valores
# cp .env.example .env.local

# Segurança (OBRIGATÓRIO mudar em produção)
JWT_SECRET=dev-secret-change-in-prod
ADMIN_PASSWORD=admin

# PostgreSQL
POSTGRES_URL=postgresql://commandops:commandops@localhost:5432/commandops_registry

# Segredo compartilhado entre Registry e módulos (service-to-service)
SERVICE_SECRET=dev-service-secret-change-in-prod

# AD Worker — autenticação Kerberos + LDAP
AD_WORKER_TOKEN=trocar-por-token-longo
AD_WORKER_KEYTAB_PATH=/opt/commandops/secrets/svc_infratools_ad.keytab
AD_REALM=COAMO.COM.BR
AD_DOMAIN=coamo.com.br
AD_BASE_DN=DC=coamo,DC=com,DC=br
AD_LDAP_SERVER=admdc01.coamo.com.br
AD_LDAP_PORT=389
AD_SERVICE_PRINCIPAL=svc_infratools_ad@COAMO.COM.BR
AD_WORKER_AUTO_KINIT=true
AD_WORKER_ALLOW_PASSWORD_OPS=false
AD_WORKER_DEFAULT_DRY_RUN=true

# Portas (opcional — padrões abaixo)
SHELL_PORT=5000
REGISTRY_PORT=5010
GATEWAY_PORT=8080
VPN_PORT=5101
